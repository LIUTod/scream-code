{
  "changelog": ["@changesets/changelog-github", { "repo": "LIUTod/scream-code", "disableThanks": true }],
  "commit": false,
  "fixed": [],
  "linked": [],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "@scream-code/agent-core",
    "@scream-code/config",
    "@scream-code/jian",
    "@scream-code/ltod",
    "@scream-code/memory",
    "@scream-code/scream-code-sdk"
  ],
  "snapshot": {
    "useCalculatedVersion": true,
    "prereleaseTemplate": "{tag}-{commit}"
  }
}
