{
  "name": "@scream-cli/config",
  "version": "0.1.0",
  "private": true,
  "description": "Platform configuration and model management for Scream Code",
  "license": "MIT",
  "author": "ScreamCli AI",
  "homepage": "https://github.com/LIUTod/scream-code/tree/main/packages/config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LIUTod/scream-code.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/LIUTod/scream-code/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && cp dist/index.d.mts dist/index.d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
