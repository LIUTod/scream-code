{
  "name": "@scream-cli/scream-telemetry",
  "version": "0.3.10",
  "private": true,
  "description": "Shared telemetry infrastructure for Scream Code",
  "license": "MIT",
  "author": "ScreamCli AI",
  "homepage": "https://github.com/LIUTod/scream-code/tree/main/packages/telemetry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LIUTod/scream-code.git",
    "directory": "packages/telemetry"
  },
  "bugs": {
    "url": "https://github.com/LIUTod/scream-code/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
