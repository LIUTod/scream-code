{
  "name": "@scream-code/knowledge",
  "version": "0.10.0",
  "private": true,
  "description": "Local knowledge base library for scream-code agent retrieval",
  "license": "MIT",
  "author": "ScreamCli AI",
  "homepage": "https://github.com/LIUTod/scream-code/tree/main/packages/knowledge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LIUTod/scream-code.git",
    "directory": "packages/knowledge"
  },
  "bugs": {
    "url": "https://github.com/LIUTod/scream-code/issues"
  },
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@scream-code/memory": "workspace:*",
    "pathe": "^2.0.3"
  }
}
